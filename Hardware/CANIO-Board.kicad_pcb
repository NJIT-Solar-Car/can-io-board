			(font
				(size 3 3)
				(thickness 0.6)
				(bold yes)
			)
			(justify left top)
		)
	)
	(gr_text "- Board is centered at (150, 115), and is 100mm*100mm.\n- Corners have 3mm fillet. PTHs are 3.5mm (support M3 screws)\n- Bottom PTHs are 4.25mm away from both edges. Top ones are 4.25mm\n   away from the left and right edges, and 25mm away from the top\n   edge. These are all from edge of board to center of PTH.\n- MCU is 20mm below the center of the board, tilted 45 degrees for\n   optimal routing.\n- Allocated space for the high-current switching logic is centered\n   at (150, 100), and is 60mm*30mm.\n- When buttons are grouped left and right, they are positioned (20, 6)\n   from the MCU.\n- Coils carry only 30mA, so safe to go with thin traces"
		(at 16.95 69.05 0)
		(layer "Dwgs.User")
		(uuid "ae8d03b5-d0b3-46d7-903e-fdba8ded54bf")
		(effects
			(font
				(size 1 1)
				(thickness 0.15)
			)
			(justify left top)
		)
	)
	(gr_text "This entire area does not use 3v3 or 5v0. In2 can be\nused to route signals."
		(at 117.25 34.8 0)
		(layer "Dwgs.User")
		(uuid "ec1f7726-45ba-4324-9048-fde37614693c")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.3)
				(bold yes)
			)
			(justify left top)
		)
	)
